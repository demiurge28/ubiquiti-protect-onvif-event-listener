#!/bin/bash
set -e
python3 -m cpplint src/*.cpp src/*.hpp test/*.cpp test/*.hpp

# bazel-remote on 127.0.0.1:9092 has intermittent hangs that block the
# build for 60+s per cache lookup.  Probe its health with a short timeout
# and skip remote cache when unresponsive so the hook still terminates
# in a reasonable time.
BZ_FLAGS=()
if ! curl -sf -m 3 http://127.0.0.1:9092/status >/dev/null 2>&1; then
    echo "[pre-push] bazel-remote unresponsive -- bypassing remote cache"
    BZ_FLAGS+=(--remote_cache=)
fi
scripts/bz test --config=x86 "${BZ_FLAGS[@]}" \
    //test:test_onvif_listener //test:test_ubv_thumbnail

# Docker ARM64 build -- validates the sysroot setup on ubuntu:24.04 (clang-18).
# Skipped silently when Docker is not available or not running.
if docker info &>/dev/null 2>&1; then
    echo "[pre-push] Docker available -- verifying ARM64 build..."
    ./build-in-docker.sh --arm64
else
    echo "[pre-push] Docker not available -- skipping ARM64 Docker build"
fi
