<Page x:Class="OnvifRecorderInstaller.Pages.ConnectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Connect">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Style="{StaticResource H1}"
                   Text="Step 2 — Connect to your router"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0"
                       VerticalAlignment="Center" Text="Host / IP:"/>
            <TextBox  Grid.Row="0" Grid.Column="1"
                      VerticalAlignment="Center"
                      x:Name="HostBox" Text="192.168.1.1"/>
            <TextBlock Grid.Row="0" Grid.Column="2"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" Text="Port:"/>
            <TextBox  Grid.Row="0" Grid.Column="3"
                      VerticalAlignment="Center"
                      x:Name="PortBox" Text="22"/>

            <TextBlock Grid.Row="1" Grid.Column="0"
                       VerticalAlignment="Center" Text="Username:"/>
            <TextBox  Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                      VerticalAlignment="Center"
                      x:Name="UserBox" Text="root"/>

            <TextBlock Grid.Row="2" Grid.Column="0"
                       VerticalAlignment="Center" Text="Auth method:"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                      VerticalAlignment="Center"
                      x:Name="AuthCombo"
                      SelectionChanged="AuthCombo_Changed"
                      SelectedIndex="0">
                <ComboBoxItem Content="Password"/>
                <ComboBoxItem Content="Private key (OpenSSH)"/>
            </ComboBox>

            <TextBlock Grid.Row="3" Grid.Column="0"
                       x:Name="SecretLabel"
                       VerticalAlignment="Center" Text="Password:"/>
            <PasswordBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                         VerticalAlignment="Center"
                         x:Name="PasswordBox"/>
            <Grid Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                  x:Name="KeyFileRow" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="KeyPathBox"
                         VerticalAlignment="Center"/>
                <Button  Grid.Column="1" Content="Browse..."
                         Click="Browse_Click"/>
            </Grid>

            <TextBlock Grid.Row="4" Grid.Column="0"
                       x:Name="PassphraseLabel"
                       VerticalAlignment="Center"
                       Text="Passphrase:" Visibility="Collapsed"/>
            <PasswordBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                         VerticalAlignment="Center"
                         x:Name="PassphraseBox" Visibility="Collapsed"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Test connection" Click="Test_Click"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Margin="12,0,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <TextBlock Grid.Row="3" x:Name="FingerprintText" Margin="0,12,0,0"
                   TextWrapping="Wrap" Foreground="#555"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Back" Click="Back_Click"/>
            <Button Content="Next" x:Name="NextButton"
                    IsDefault="True" IsEnabled="False"
                    Click="Next_Click"/>
        </StackPanel>
    </Grid>
</Page>
