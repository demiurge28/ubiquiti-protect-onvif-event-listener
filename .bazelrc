build --cxxopt=-std=c++17
build --cxxopt=-Wall
build --cxxopt=-Wextra
build --cxxopt=-O2
build --cxxopt=-pthread
build --linkopt=-pthread
build --cxxopt=-fno-exceptions
build --cxxopt=-fno-rtti

# Cross-compile to arm64: bazel build --config=arm64 //:onvif_recorder
# Packages are downloaded on first use and cached in Bazel's output base.
build:arm64 --platforms=//platforms:linux_arm64
build:arm64 --extra_toolchains=@arm64_sysroot//:aarch64_toolchain

# Use clang for x86 builds (consistent compiler family with the ARM64
# cross-toolchain; required for LLVM PGO instrumentation/profile format).
build:clang --repo_env=CC=clang
build:clang --repo_env=CXX=clang++

# PGO step 1 -- instrument the binary to collect a profile.
# Use with --config=clang for x86; the ARM64 toolchain already uses clang.
build:pgo_instrument --copt=-fprofile-instr-generate
build:pgo_instrument --linkopt=-fprofile-instr-generate

# ThinLTO -- fast whole-program optimisation; combine with pgo_optimize.
build:lto --copt=-flto=thin
build:lto --linkopt=-flto=thin

# ARM64 release build: native QEMU-collected PGO profile + ThinLTO.
# Requires pgo_arm64.profdata to exist (committed to the repo).
# Collect/refresh it with: scripts/bz run --config=arm64 //:pgo_collect_arm64
build:arm64_release --config=arm64
build:arm64_release --config=lto
build:arm64_release --fdo_profile=//:pgo_arm64

# Sanitizer builds -- requires --config=clang; incompatible with each other
# and with --config=arm64.
# Usage:
#   bazel test --config=clang --config=asan //test:all
#   bazel test --config=clang --config=tsan //test:all
#   bazel test --config=clang --config=msan //test:all   # needs instrumented libc
build:asan --copt=-fsanitize=address
build:asan --linkopt=-fsanitize=address
build:asan --copt=-fno-omit-frame-pointer
build:asan --copt=-O1

build:tsan --copt=-fsanitize=thread
build:tsan --linkopt=-fsanitize=thread
build:tsan --copt=-fno-omit-frame-pointer
build:tsan --copt=-O1

build:msan --copt=-fsanitize=memory
build:msan --linkopt=-fsanitize=memory
build:msan --copt=-fno-omit-frame-pointer
build:msan --copt=-fsanitize-memory-track-origins
build:msan --copt=-O1

# ---------------------------------------------------------------------------
# Composite configs: arch × mode
# Each maps to its own --output_base via the bz wrapper (scripts/bz), which
# prevents analysis-cache invalidation when switching between configs.
#
# Usage (via bz wrapper):
#   bz build --config=x86 //:onvif_recorder
#   bz test  --config=x86_asan //test:all
#   bz test  --config=x86_tsan //test:all
#   bz test  --config=x86_msan //test:all    # needs instrumented libc
#   bz build --config=arm64 //:onvif_recorder
#   bz build --config=arm64_release //:onvif_recorder
# ---------------------------------------------------------------------------
build:x86      --config=clang

build:x86_asan --config=clang
build:x86_asan --config=asan

build:x86_tsan --config=clang
build:x86_tsan --config=tsan

build:x86_msan --config=clang
build:x86_msan --config=msan
